# Streamlit Secrets サンプル
# -----------------------------------------------------------
# 【ローカル】このファイルを secrets.toml にコピーして値を入れる
#            （secrets.toml は .gitignore 済み＝コミットされない）
# 【Streamlit Cloud】管理画面の Settings > Secrets に下記を貼り付ける
# -----------------------------------------------------------

# Gemini APIキー（https://aistudio.google.com/apikey）
GEMINI_API_KEY = "ここにAPIキー"

# 社内限定アクセス用パスワード（空にすると認証なし＝ローカル開発用）
APP_PASSWORD = "社内で共有する合言葉"
